# App runtime
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
ALLOWED_GOOGLE_DOMAIN=zodl.com
# Optional second Google OAuth client for external guest sign-in.
# Keep disabled unless guest login is intentionally enabled.
GUEST_GOOGLE_OAUTH_ENABLED=false
GOOGLE_GUEST_CLIENT_ID=
GOOGLE_GUEST_CLIENT_SECRET=
# Guest email-link sign-in for explicit allowlisted external users.
GUEST_MAGIC_LINK_ENABLED=false
GUEST_MAGIC_LINK_MAX_AGE_SECONDS=900
GUEST_MAGIC_LINK_FROM_ADDRESS=
GUEST_MAGIC_LINK_FROM_NAME=ZODL Dashboard
# Comma/space-separated exact email allowlist for guest auth providers.
ALLOWED_GUEST_GOOGLE_EMAILS=kenbak@atmospherelabs.dev,thor@thortorrens.com

# Optional local-network auth bypass (disabled by default)
LOCAL_BYPASS_ENABLED=false
LOCAL_BYPASS_KILL_SWITCH=false
# DDNS hostname used to discover your current home egress IP(s)
# Example: chat.paulbrigner.com
LOCAL_BYPASS_DDNS_HOST=
# Optional static comma-separated allowlist (IPv4/IPv6)
LOCAL_BYPASS_ALLOWLIST_IPS=
# How often to refresh DDNS resolution for LOCAL_BYPASS_DDNS_HOST
LOCAL_BYPASS_REFRESH_SECONDS=300
# Client-IP extraction strategy:
# strict: require trusted proxy hops in X-Forwarded-For (recommended)
# rightmost: trust the right-most X-Forwarded-For hop
LOCAL_BYPASS_IP_SOURCE_STRATEGY=strict
# Trusted proxy hop IPs for strict mode (comma-separated)
LOCAL_BYPASS_TRUSTED_PROXY_IPS=
# Optional explicit trusted client-IP header (overrides X-Forwarded-For parsing)
# Example (CloudFront): cloudfront-viewer-address
LOCAL_BYPASS_CLIENT_IP_HEADER=
# Displayed identity in UI when bypass is active
LOCAL_BYPASS_DISPLAY_EMAIL=local-network@zodldashboard.local
# Log allow/deny decisions for bypass checks
LOCAL_BYPASS_LOG_DECISIONS=true

# API runtime
XMONITOR_API_SERVICE_NAME=xmonitor-api
XMONITOR_API_VERSION=v1
XMONITOR_DEFAULT_FEED_LIMIT=50
XMONITOR_MAX_FEED_LIMIT=200

# Regulatory Risk dashboard runtime data source (optional)
# If set, this URL should return a full data_bundle_v1_1.json payload.
REGULATORY_RISK_DATA_URL=
# Generic fallback key used by regulatory dashboard when specific key above is unset.
DATA_URL=

# Read/proxy API routing (optional)
# If set, UI reads from this backend instead of direct DB access.
# Example: https://www.zodldashboard.com/api/v1
XMONITOR_READ_API_BASE_URL=
# If set, local /api/v1 routes proxy to this backend.
# Example: https://abc123.execute-api.us-east-1.amazonaws.com/prod/v1
XMONITOR_BACKEND_API_BASE_URL=
# Request timeout for proxy mode (milliseconds)
XMONITOR_API_PROXY_TIMEOUT_MS=15000

# Ingest auth (server-side secret expected by /ingest routes)
XMONITOR_INGEST_SHARED_SECRET=replace-with-a-long-random-shared-secret
# Optional compatibility alias for ingest auth (fallback if secret above is unset)
XMONITOR_API_KEY=
# Optional comma/space-separated handle omit list for keyword-origin ingest only (normalized, no @)
# (watchlist-tier posts are never omitted by this rule)
# Repo defaults live in config/xmonitor/omit-handles.json; set this only to extend/override locally.
XMONITOR_INGEST_OMIT_HANDLES=

# Semantic retrieval (Stage One)
XMONITOR_SEMANTIC_ENABLED=true
XMONITOR_SEMANTIC_DEFAULT_LIMIT=25
XMONITOR_SEMANTIC_MAX_LIMIT=100
XMONITOR_SEMANTIC_MIN_SCORE=0
XMONITOR_EMBEDDING_BASE_URL=https://api.venice.ai/api/v1
XMONITOR_EMBEDDING_MODEL=text-embedding-bge-m3
XMONITOR_EMBEDDING_DIMS=1024
XMONITOR_EMBEDDING_TIMEOUT_MS=10000
# Preferred secret name for embedding calls (server-side only)
XMONITOR_EMBEDDING_API_KEY=
# Optional fallback used by current runtime if XMONITOR_EMBEDDING_API_KEY is unset
VENICE_API_KEY=

# Compose (Stage 2 retrieval + answer)
XMONITOR_COMPOSE_ENABLED=true
XMONITOR_COMPOSE_DRAFTS_ENABLED=true
XMONITOR_COMPOSE_DEFAULT_RETRIEVAL_LIMIT=150
XMONITOR_COMPOSE_MAX_RETRIEVAL_LIMIT=150
XMONITOR_COMPOSE_DEFAULT_CONTEXT_LIMIT=32
XMONITOR_COMPOSE_MAX_CONTEXT_LIMIT=32
XMONITOR_COMPOSE_ASYNC_ENABLED=true
XMONITOR_COMPOSE_JOBS_QUEUE_URL=
XMONITOR_COMPOSE_JOB_POLL_MS=2500
XMONITOR_COMPOSE_JOB_TTL_HOURS=24
XMONITOR_COMPOSE_JOB_MAX_ATTEMPTS=3
XMONITOR_ENABLE_COMPOSE_JOBS_SCHEMA_BOOTSTRAP=false
XMONITOR_COMPOSE_BASE_URL=https://api.venice.ai/api/v1
XMONITOR_COMPOSE_MODEL=openai-gpt-54
XMONITOR_COMPOSE_TIMEOUT_MS=120000
# Optional token cap. Leave empty to let provider decide completion length.
XMONITOR_COMPOSE_MAX_OUTPUT_TOKENS=
XMONITOR_COMPOSE_MAX_DRAFT_CHARS=1200
XMONITOR_COMPOSE_MAX_DRAFT_CHARS_X_POST=280
XMONITOR_COMPOSE_MAX_CITATIONS=10
XMONITOR_COMPOSE_MAX_REQUESTS_PER_MINUTE=30
XMONITOR_COMPOSE_MAX_CONCURRENCY=4
XMONITOR_COMPOSE_MAX_ESTIMATED_COST_USD=0.5
XMONITOR_COMPOSE_INPUT_COST_PER_1M_TOKENS=0.15
XMONITOR_COMPOSE_OUTPUT_COST_PER_1M_TOKENS=0.6
XMONITOR_COMPOSE_USE_JSON_MODE=true
XMONITOR_COMPOSE_DISABLE_THINKING=true
XMONITOR_COMPOSE_STRIP_THINKING_RESPONSE=true
# Preferred secret name for compose calls (server-side only)
XMONITOR_COMPOSE_API_KEY=

# Email draft + send + scheduling (Answer Mode)
# Shared proxy secret must match on web and backend runtimes.
XMONITOR_USER_PROXY_SECRET=
XMONITOR_EMAIL_ENABLED=false
XMONITOR_EMAIL_SCHEDULES_ENABLED=false
XMONITOR_EMAIL_REQUIRE_OAUTH=true
XMONITOR_EMAIL_FROM_ADDRESS=
XMONITOR_EMAIL_FROM_NAME=ZodlDashboard X Monitor
XMONITOR_EMAIL_MAX_RECIPIENTS=10
XMONITOR_EMAIL_MAX_JOBS_PER_USER=25
XMONITOR_EMAIL_MAX_BODY_CHARS=20000
XMONITOR_EMAIL_SCHEDULE_DISPATCH_LIMIT=25
# Enables idempotent bootstrap of scheduled email + deliveries schema inside the VPC Lambda.
XMONITOR_ENABLE_EMAIL_SCHEMA_BOOTSTRAP=false

# Optional AWS Lambda collector (priority + watchlist replies via X API)
XMON_COLLECTOR_ENABLED=true
XMON_COLLECTOR_WRITE_ENABLED=true
XMON_COLLECTOR_DRY_RUN=false
XMON_COLLECTOR_SOURCE=aws-lambda-x-api
XMON_X_API_BEARER_TOKEN=
XMON_X_API_BASE_URL=https://api.x.com/2
XMON_X_API_BASE_TERMS=Zcash OR ZEC OR Zodl OR #ZODL OR Zashi
XMON_X_API_MAX_RESULTS_PER_QUERY=100
XMON_X_API_MAX_PAGES_PER_QUERY=2
XMON_X_API_HANDLE_CHUNK_SIZE=16
XMON_X_API_REPLY_CAPTURE_ENABLED=true
XMON_X_API_REPLY_MODE=term_constrained
XMON_X_API_REPLY_TIERS=teammate,influencer,ecosystem
XMON_X_API_REPLY_SELECTED_HANDLES=
XMON_X_API_ENFORCE_LANG_ALLOWLIST=true
XMON_X_API_LANG_ALLOWLIST=en
XMON_X_API_EXCLUDE_RETWEETS=true
XMON_X_API_EXCLUDE_QUOTES=false
XMON_X_API_QUERY_TIMEOUT_MS=15000
XMON_X_API_REQUEST_PAUSE_MS=200
XMON_X_API_WATCHLIST_TIERS_JSON=
XMON_X_API_WATCHLIST_INCLUDE_HANDLES=
XMON_INGEST_TIMEOUT_MS=20000
XMON_INGEST_BATCH_SIZE=200

# Async significance classifier
XMON_SIGNIFICANCE_ENABLED=true
XMON_SIGNIFICANCE_INGEST_API_BASE_URL=https://www.zodldashboard.com/api/v1
XMON_SIGNIFICANCE_INGEST_API_KEY=
XMON_SIGNIFICANCE_INGEST_TIMEOUT_MS=20000
XMON_SIGNIFICANCE_LLM_URL=https://api.venice.ai/api/v1
XMON_SIGNIFICANCE_LLM_MODEL=google-gemma-3-27b-it
XMON_SIGNIFICANCE_LLM_API_KEY=
XMON_SIGNIFICANCE_LLM_TEMPERATURE=0
XMON_SIGNIFICANCE_LLM_MAX_TOKENS=1400
XMON_SIGNIFICANCE_LLM_TIMEOUT_MS=120000
XMON_SIGNIFICANCE_LLM_MAX_ATTEMPTS=3
XMON_SIGNIFICANCE_LLM_INITIAL_BACKOFF_MS=1000
XMON_SIGNIFICANCE_BATCH_SIZE=4
XMON_SIGNIFICANCE_MAX_POSTS_PER_RUN=24
XMON_SIGNIFICANCE_MAX_ATTEMPTS=3
XMON_SIGNIFICANCE_LEASE_SECONDS=300
XMON_SIGNIFICANCE_VERSION=ai_v2

# PostgreSQL connection (use DATABASE_URL or individual PG* vars)
# DATABASE_URL=postgres://user:password@localhost:5432/xmonitor
PGHOST=localhost
PGPORT=5432
PGDATABASE=xmonitor
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable
